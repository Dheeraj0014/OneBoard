# ── Server ────────────────────────────────────────────────────────────────
PORT=8787

# Default search region (two-letter ISO code) when the client doesn't pick one.
# "in" = India (the app default), "us" = United States, etc. Users can switch
# region from the Country filter in the UI on any request.
DEFAULT_COUNTRY=in

# ── Greenhouse & Lever (public company boards, NO key needed) ────────────────
# Each value is a comma-separated list of board tokens — the slug in the board
# URL, e.g. "cloudflare" from boards.greenhouse.io/cloudflare, or "leadiq" from
# jobs.lever.co/leadiq. Unreachable tokens are skipped gracefully. Leave blank
# to disable that source. Company-board listings are localized to the selected
# region by matching each posting's location (remote roles always show).
GREENHOUSE_BOARDS=gitlab,elastic,mongodb,cloudflare,stripe,airbnb,coinbase,datadog
LEVER_BOARDS=netflix,spotify,plaid,palantir

# ── Clerk (sign-in, and the gate on the paid AI routes) ─────────────────────
# The AI routes below spend AI provider credits on every call, so the server only
# serves them to a signed-in user. Without these keys those routes refuse with a
# 503 (the app still works — it falls back to the local heuristic ranker).
# Get keys at https://dashboard.clerk.com/. The publishable key is safe to expose;
# the secret key is not. CLERK_PUBLISHABLE_KEY defaults to the VITE_ value below.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Browser origins allowed to call the API (CSV). Defaults to the Vite dev server.
# The app's OWN origin is always allowed, so a single-service deploy (where this
# server also serves dist/) needs nothing here. Only set it when the front-end is
# hosted somewhere else — anything not listed is refused with a 403, so another
# site cannot drive the AI routes on our bill.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Production / deploy ─────────────────────────────────────────────────────
# NODE_ENV=production makes this server also serve the built client from dist/,
# so the API and the front-end share one origin. (Set SERVE_STATIC=true to force
# it on outside production.) Run `npm run build` first.
# NODE_ENV=production

# Behind a hosting proxy (Render, Fly, Railway…) the real client IP arrives in
# X-Forwarded-For. Without this, every visitor shares one rate-limit bucket.
# Leave it off when running directly on your own machine — trusting a forwarded
# header that nothing sets would let a caller spoof their IP past the limits.
# TRUST_PROXY=true

# ── Rate limits (abuse / cost control) ──────────────────────────────────────
# /api/jobs is public and every distinct ?q= is a cache miss that spends real
# SerpAPI quota, so it is capped per IP. The AI routes spend AI provider credits
# and are capped per signed-in user (sign-up is open, so an IP cap alone would
# not stop one person spreading load across addresses).
RL_JOBS_PER_MIN=20
RL_RESUME_PER_MIN=5
RL_AI_PER_MIN=10
RL_AI_PER_DAY=120
# Distinct query result-sets held in memory. Bounded so a loop over ?q=aa,ab,ac…
# cannot grow the cache without limit.
CACHE_MAX_ENTRIES=300

# ── Google AI Studio / Gemini (AI ranker + resume matcher + intro drafter) ──
# Powers the AI match ranking and the outreach-intro drafter. The key stays on
# the server and is never sent to the browser. Without it, those AI features
# fall back to a local heuristic / template.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
AI_MODEL=gemini-flash-lite-latest

# ── SerpApi (Google Jobs engine) ────────────────────────────────────────────
# Aggregates Google-for-Jobs listings (LinkedIn, Indeed, Glassdoor, company
# boards, …). Get a key at https://serpapi.com/. Without a key the source is
# skipped. SERPAPI_LOCATION is an optional location bias, e.g. "United States".
SERPAPI_KEY=
SERPAPI_LOCATION=India
# SERPAPI_COUNTRY is the two-letter Google country code (gl) that actually
# restricts results to a country — "in" = India, "us" = US. This is the strong
# lever; SERPAPI_LOCATION alone only biases. SERPAPI_LANG is the UI language.
SERPAPI_COUNTRY=in
SERPAPI_LANG=en
# Number of result pages to fetch (~10 jobs each). Each page costs one search
# against your SerpApi quota. Default 3.
SERPAPI_PAGES=3

# ── Adzuna (licensed aggregator, free tier) ─────────────────────────────────
# Register at https://developer.adzuna.com/ to get an app id + key.
# Without these, the Adzuna source is simply skipped (app still works).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Fallback Adzuna market if a request arrives without a region. The UI's Country
# filter overrides this per request. Defaults to India.
ADZUNA_COUNTRY=in

# ── JSearch via RapidAPI (aggregates Google-for-Jobs listings) ──────────────
# Subscribe to JSearch at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Without a key, the JSearch source is skipped.
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com

# ── TheirStack (licensed search, Indian job market) ─────────────────────────
# Get an API key at https://app.theirstack.com/ (credit-based; each search
# costs credits, so results are cached for 15 min). Without a key the source
# is skipped. Location ids default to India (1269750); override as a CSV.
THEIRSTACK_API_KEY=
THEIRSTACK_LOCATION_IDS=1269750
THEIRSTACK_MAX_AGE_DAYS=7
THEIRSTACK_LIMIT=25
