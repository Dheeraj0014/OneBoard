# ── Server ────────────────────────────────────────────────────────────────
PORT=8787

# Default search region (two-letter ISO code) when the client doesn't pick one.
# "in" = India (the app default), "us" = United States, etc. Users can switch
# region from the Country filter in the UI on any request.
DEFAULT_COUNTRY=in

# ── Greenhouse & Lever (public company boards, NO key needed) ────────────────
# Each value is a comma-separated list of board tokens — the slug in the board
# URL, e.g. "cloudflare" from boards.greenhouse.io/cloudflare, or "leadiq" from
# jobs.lever.co/leadiq. Unreachable tokens are skipped gracefully. Leave blank
# to disable that source. Company-board listings are localized to the selected
# region by matching each posting's location (remote roles always show).
GREENHOUSE_BOARDS=gitlab,elastic,mongodb,cloudflare,stripe,airbnb,coinbase,datadog
LEVER_BOARDS=netflix,spotify,plaid,palantir

# ── Anthropic (AI ranker + intro drafter) ───────────────────────────────────
# Powers the AI match ranking and the outreach-intro drafter. The key stays on
# the server and is never sent to the browser. Without it, those AI features
# fall back to a local heuristic / template. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ── SerpApi (Google Jobs engine) ────────────────────────────────────────────
# Aggregates Google-for-Jobs listings (LinkedIn, Indeed, Glassdoor, company
# boards, …). Get a key at https://serpapi.com/. Without a key the source is
# skipped. SERPAPI_LOCATION is an optional location bias, e.g. "United States".
SERPAPI_KEY=
SERPAPI_LOCATION=India
# SERPAPI_COUNTRY is the two-letter Google country code (gl) that actually
# restricts results to a country — "in" = India, "us" = US. This is the strong
# lever; SERPAPI_LOCATION alone only biases. SERPAPI_LANG is the UI language.
SERPAPI_COUNTRY=in
SERPAPI_LANG=en
# Number of result pages to fetch (~10 jobs each). Each page costs one search
# against your SerpApi quota. Default 3.
SERPAPI_PAGES=3

# ── Adzuna (licensed aggregator, free tier) ─────────────────────────────────
# Register at https://developer.adzuna.com/ to get an app id + key.
# Without these, the Adzuna source is simply skipped (app still works).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Fallback Adzuna market if a request arrives without a region. The UI's Country
# filter overrides this per request. Defaults to India.
ADZUNA_COUNTRY=in

# ── JSearch via RapidAPI (aggregates Google-for-Jobs listings) ──────────────
# Subscribe to JSearch at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Without a key, the JSearch source is skipped.
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com

# ── TheirStack (licensed search, Indian job market) ─────────────────────────
# Get an API key at https://app.theirstack.com/ (credit-based; each search
# costs credits, so results are cached for 15 min). Without a key the source
# is skipped. Location ids default to India (1269750); override as a CSV.
THEIRSTACK_API_KEY=
THEIRSTACK_LOCATION_IDS=1269750
THEIRSTACK_MAX_AGE_DAYS=7
THEIRSTACK_LIMIT=25
